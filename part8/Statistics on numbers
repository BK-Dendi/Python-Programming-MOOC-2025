class  NumberStats:
    def __init__(self):
        self.numbers = 0
        self.new_list = []

    def add_number(self, number:int):
        self.new_list.append(number)

    def count_numbers(self):
        return len(self.new_list)

    def get_sum(self):
        return sum(self.new_list)
    
    def average(self):
        if len(self.new_list) != 0:
            return (sum(self.new_list) / len(self.new_list))
        else:
            return 0
        

print("Please type in integer numbers:")
stats = NumberStats()
even = NumberStats()
odd = NumberStats()
while True:
    n = int(input())
    
    if n == -1:
        break
    stats.add_number(n)

    if n % 2 == 0:
        even.add_number(n)
    else:
        odd.add_number(n)
        

print("Numbers added:", stats.count_numbers())
print("Sum of numbers:", stats.get_sum())
print("Mean of numbers:", stats.average())
print("Sum of even numbers:", even.get_sum())
print("Sum of odd numbers:", odd.get_sum())
