class LotteryNumbers:

  def __init__(self,week: int, seven: list):
    self.__week =  week
    self.__seven = seven

  def number_of_hits(self,numbers: list):
    return len([num for num in numbers if num in self.__seven])

  def hits_in_place(self,numbers):
    return [num if num in self.__seven else -1 for num in numbers]
