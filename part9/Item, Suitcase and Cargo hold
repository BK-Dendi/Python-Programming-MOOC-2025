class Item:
  def __init__(self,name,weight):
      self.__name = name
      self.__weight = weight
  
  def name(self):
      return self.__name
  
  def weight(self):
      return self.__weight

  def __str__(self):
      return f"{self.__name} ({self.__weight} kg)"

class Suitcase:

  def __init__(self,max_weight):
    self.__max_weight = max_weight
    self.__weight = 0
    self.__count = 0
    self.__items = []

  def add_item(self, item):
    if self.__max_weight >= self.__weight + item.weight():
      self.__weight += item.weight()
      self.__count += 1
    
    self.__items.append(item)

  def __str__(self):
    if self.__count == 1:
      return f"{self.__count} item ({self.__weight} kg)"
    else:
      return f"{self.__count} items ({self.__weight} kg)"

  def print_items(self):
    for item in self.__items:
      print(item)

  def weight(self):
    return sum(item.weight() for item in self.__items)

  def heaviest_item(self):
    if len(self.__items) == 0:
      return None
    heavy = 0
    for item in self.__items:
      if item.weight() > heavy:
        heavy = item.weight()
      
    for item in self.__items:
      if item.weight() == heavy:
        return item
    
    
class CargoHold:

  def __init__(self,max_weight):
    self.__max_weight = max_weight
    self.__count = 0
    self.__cargos = []

  def add_suitcase(self, suitcase):
    if self.__max_weight >= suitcase.weight() :
      self.__max_weight -= suitcase.weight()
      self.__count += 1
    self.__cargos.append(suitcase)

  def __str__(self):

    if self.__count == 1:
      return f"{self.__count} suitcase, space for {self.__max_weight} kg"
    else:
      return f"{self.__count} suitcases, space for {self.__max_weight} kg"

  def print_items(self):
    for cargo in self.__cargos:
      cargo.print_items()


