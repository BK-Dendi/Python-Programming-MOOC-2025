class ListHelper:

  @classmethod
  def greatest_frequency(cls, my_list: list):
    greatest_count = 1
    max_element = my_list[0]

    for i in my_list:
      if my_list.count(i) > greatest_count:
        greatest_count = my_list.count(i)
        max_element = i

    return max_element

  
  @classmethod
  def doubles(cls, my_list: list):
    my_set = set(my_list)
    const = 0

    for i in my_set:
      if my_list.count(i) >= 2:
        const += 1 
    return const 

  
