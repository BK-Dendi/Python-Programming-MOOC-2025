# Write your solution here

filename = "diary.txt"

while True:
  print("1 - add an entry, 2 - read entries, 0 - quit")
  function = int(input("Function:"))

  if function == 1:
    text = input("Diary entry:")
    with open(filename, "a") as file:
      file.write(f"{text}\n")
    
    print("Diary saved")
  
  elif function == 2:
    print("Entries:\n")
    with open(filename, "r") as file:
      for line in file:
        line = line.replace("\n", "")
        print(f"{line}\n")
  else:
    break

print("Bye now!")
