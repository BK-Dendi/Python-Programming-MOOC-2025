def students(exercise_data:str):
  grades = {}
  with open(exercise_data) as file:
    for line in file:
      line = line.replace("\n","")
      parts = line.split(";")
      if parts[0] == "id":
        continue
      grades[parts[0]] = 0
      for grade in parts[1:]:
        grades[parts[0]] += int(grade)

  return grades

def exercises(student_info:str):
  students = {}
  with open(student_info) as file:
    for line in file:
      line = line.replace("\n","")
      parts = line.split(";")
      if parts[0] == "id":
        continue
      students[parts[0]] = parts[1] + " " + parts[2]
  return students

def main():
  if True:
    student_info = input("Student information: ")
    exercise_data = input("Exercises completed: ")
  else:
    student_info = "students1.csv"
    exercise_data = "exercises1.csv"
  
  students1 = students(exercise_data)
  exercises1 = exercises(student_info)

  for id, name in exercises1.items():
    if id in students1:
      grade = students1[id]
    print(f"{name} {grade}")

main()
