def students(student_info:str):
  students = {}
  with open(student_info) as file:
    for line in file:
      line = line.replace("\n","")
      parts = line.split(";")
      if parts[0] == "id":
        continue

      students[parts[0]] = parts[1] + " " + parts[2]
  return students

def exercises(exercise_data:str):
  exercises = {}
  with open(exercise_data) as file:
    for line in file:
      line = line.replace("\n","")
      parts = line.split(";")
      if parts[0] == "id":
        continue
      exercises[parts[0]] = 0 
      for grade in parts[1:]:
        exercises[parts[0]] += int(grade)

  return exercises 

def exams(exams_info:str):
  exams = {}
  with open(exams_info) as file:
    for line in file:
      line = line.replace("\n","")
      parts = line.split(";")
      if parts[0] == "id":
        continue
      exams[parts[0]] = 0
      for exam in parts[1:]:
        exams[parts[0]] += int(exam)
  return exams 

def main():
  if True:
    student_info = input("Student information: ")
    exercise_data = input("Exercises completed: ")
    exams_info = input("Exams completed: ")
  else:
    student_info = "students1.csv"
    exercise_data = "exercises1.csv"
    exams_info = "exam_points1.csv"
  
  students1 = students(student_info)
  exercises1 = exercises(exercise_data)
  exams1 = exams(exams_info)
  final_grade = 0
  for id, name in students1.items():
    if id in exercises1:
      sum_value = exams1[id] + int(exercises1[id] // 4)
    if sum_value <= 14:
        final_grade = 0
    elif sum_value <= 17:
        final_grade = 1
    elif sum_value <= 20:
        final_grade = 2
    elif sum_value <= 23:
        final_grade = 3
    elif sum_value <= 27:
        final_grade = 4
    else:
        final_grade = 5
    print( f"{name} {final_grade}")

main()
