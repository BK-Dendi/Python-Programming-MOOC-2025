from functools import reduce

class CourseAttempt:
    def __init__(self, course_name: str, grade: int, credits: int):
        self.course_name = course_name
        self.grade = grade
        self.credits = credits

    def __str__(self):
        return f"{self.course_name} ({self.credits} cr) grade {self.grade}"

# Write your solution
def sum_of_all_credits(items:list):
    return reduce(lambda x, y: x + y.credits, items, 0)

def sum_of_passed_credits(items:list):
    new_list = filter(lambda x: x.grade >= 1, items)
    return reduce(lambda x,y: x + y.credits, new_list, 0)

def average(items:list):
    new_list = filter(lambda x: x.grade > 0, items)
    sum_value = reduce(lambda x, y: x + y.grade, new_list, 0)
    count = len(list(filter(lambda x: x.grade > 0, items)))
    return sum_value / count 

