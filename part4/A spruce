def spruce(size):
    print("a spruce!")
    row = "*"
    n = size
    while n > 0:
        print(" " * (n-1) + row)
        row += "**"
        n -= 1
    
    print(" "  * (size -  1)  + "*")



if __name__ == "__main__":
    spruce(5)
