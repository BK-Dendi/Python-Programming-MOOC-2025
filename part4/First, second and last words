def first_word(word):

    i = word.find(" ")

    return word[:i]

def second_word(word):

    i = word.find(" ")
    j = word.find(" ", i + 1) 
    
    if j == -1:
        return word[i+1:]
    else:
        return word[i+1: j]

def last_word(word):

    i = len(word)
    j = word.rfind(" ")
    return word[j+1:]


if __name__ == "__main__":
    sentence = "first second"
    print(first_word(sentence))
    print(second_word(sentence))
    print(last_word(sentence))
