from random import *
from string import *

def generate_strong_password(amount:int, first:bool, second:bool):
  word = ascii_lowercase
  special_char = "!?=+-()#"
  password = []
  if first:
    password.append(choice(digits))
    word += digits
  if second:
    password.append(choice(special_char))
    word += special_char
  
  while len(password) < amount:
    password.append(choice(word))

  shuffle(password)
  return "".join(password)
  
