from string import *

def separate_characters(my_string: str):
  first = "".join([i for i in my_string if i in ascii_letters])
  second = "".join([i for i in my_string if i in punctuation])
  third = "".join([i for i in my_string if i not in punctuation + ascii_letters])
  return first,second,third

